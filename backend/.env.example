APP_PORT=8080
APP_ENV=development

# Conexões MySQL — uma DSN por alias canônico
# Formato: user:password@tcp(host:port)/database?parseTime=true&loc=Local
DB_SMID_DSN=user:pass@tcp(127.0.0.1:3306)/smid?parseTime=true&loc=Local&charset=utf8mb4
DB_PERMISSION_DSN=user:pass@tcp(127.0.0.1:3306)/permission?parseTime=true&loc=Local&charset=utf8mb4
DB_LOG_DSN=user:pass@tcp(127.0.0.1:3306)/log?parseTime=true&loc=Local&charset=utf8mb4
DB_COMMUNICATION_DSN=user:pass@tcp(127.0.0.1:3306)/communication?parseTime=true&loc=Local&charset=utf8mb4

# Connection pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=30

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=8
JWT_REFRESH_EXPIRATION_HOURS=168

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
